{% extends 'base.html.twig' %}

{% block title %}Suche{% endblock %}

{% block body %}
    <h1>Fragen suchen</h1>

    <form method="get" action="{{ path('app_questions_search') }}">
        <input type="text" name="q" value="{{ search }}" placeholder="Suchbegriff...">
        <button type="submit">Suchen</button>
    </form>

    {% if search %}
        <p>Ergebnisse für: <strong>{{ search }}</strong></p>

        {% if questions is empty %}
            <p>Keine Fragen gefunden.</p>
        {% else %}
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Text</th>
                        <th>Lektion</th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    {% for question in questions %}
                        <tr>
                            <td>{{ question.id }}</td>
                            <td>{{ question.text }}</td>
                            <td>{{ question.lesson.title }}</td>
                            <td>
                                <a href="{{ path('app_question', { id: question.id }) }}">Details</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    {% endif %}
{% endblock %}