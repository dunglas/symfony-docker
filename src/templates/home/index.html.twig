{% set percentage = total > 0 ? (done / total * 100)|round : 0 %}

<h1>Willkommen</h1>

<h2>Fortschritt</h2>
<p>{{ done }} / {{ total }} Lektionen abgeschlossen</p>

<div style="background:#e0e0e0; border-radius:8px; height:24px; width:100%;">
    <div style="background:#4caf50; width:{{ percentage }}%; height:100%; border-radius:8px; transition: width 0.3s;">
    </div>
</div>
<p>{{ percentage }}%</p>

