{% extends 'base.html.twig' %}

{% block body %}
    {% set percentage = total > 0 ? (done / total * 100)|round : 0 %}

    <h1>Willkommen</h1>

    <h2>Fortschritt</h2>
    <p>{{ done }} / {{ total }} Lektionen abgeschlossen</p>

    <div class="progress-bar">
        <div class="progress-bar-fill" style="width:{{ percentage }}%;"></div>
    </div>
    <p>{{ percentage }}%</p>

    <h2>Fragen</h2>
    <ul>
        <li><a href="{{ path('app_questions') }}">Alle Fragen</a></li>
        <li><a href="{{ path('app_question_new') }}">Neue Frage erstellen</a></li>
        <li><a href="{{ path('app_questions_search') }}">Fragen suchen</a></li>
    </ul>

    <h2>Simulation</h2>
    <ul>
        <li><a href="{{ path('app_simulation') }}">Lesson auswählen</a></li>
    </ul>
{% endblock %}